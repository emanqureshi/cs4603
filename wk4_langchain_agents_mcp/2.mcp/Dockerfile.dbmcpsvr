# Dockerfile for the Chinook MCP server (4.4.mcp_server_db.py).
#
# It bundles the SQLite database AND the MCP server, then serves it over the
# streamable-http transport so any networked client can connect to
#   http://<container-host>:8000/mcp
#
# Build (run from the wk4_langchain_agents_mcp folder):
#   docker build -f Dockerfile.dbmcpsvr -t chinook-mcp .
#
# Run (publish the port so clients outside the container can reach it):
#   docker run --rm -p 8000:8000 chinook-mcp
#
# Then point an MCP client at:  http://localhost:8000/mcp

FROM python:3.12-slim

# Don't write .pyc files and keep stdout/stderr unbuffered so logs stream out.
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

# Install Python deps first so this layer is cached unless requirements change.
COPY requirements.dbmcpsvr.txt ./
RUN pip install --no-cache-dir -r requirements.dbmcpsvr.txt

# Copy the server code and the Chinook database (read-only at runtime).
COPY 4.4.mcp_server_db.py ./
COPY resources/Chinook.db ./resources/Chinook.db

# Network settings: bind to 0.0.0.0 so the port is reachable from outside the
# container, serve the streamable-http transport, and expose port 8000.
ENV MCP_TRANSPORT=http \
    MCP_HOST=0.0.0.0 \
    MCP_PORT=8000
EXPOSE 8000

# Run as a non-root user for safety.
RUN useradd --create-home appuser && chown -R appuser /app
USER appuser

CMD ["python", "4.4.mcp_server_db.py"]
